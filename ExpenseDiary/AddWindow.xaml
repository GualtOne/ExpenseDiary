<Window x:Class="ExpenseDiary.AddWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление записи" Height="400" Width="350"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <StackPanel>
            <TextBlock Text="Дата:" Margin="0,0,0,5"/>
            <DatePicker x:Name="DatePicker" SelectedDate="{Binding Date, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                        IsTodayHighlighted="True" Margin="0,0,0,10"/>
            
            <TextBlock Text="Сумма:" Margin="0,0,0,5"/>
            <TextBox x:Name="SumTextBox" Text="0" PreviewTextInput="NumberValidationTextBox" Margin="0,0,0,10"/>

            <TextBlock Text="Категория:" Margin="0,0,0,5"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <RadioButton x:Name="ExpenseRadio" Content="Расход" GroupName="TransactionType" IsChecked="True" Margin="0,0,15,0"/>
                <RadioButton x:Name="IncomeRadio" Content="Доход" GroupName="TransactionType"/>
            </StackPanel>

            <TextBlock Text="Комментарий:" Margin="0,0,0,5"/>
            <TextBox x:Name="CommentTextBox" Text="Новая запись" AcceptsReturn="True" MinHeight="50" 
                     TextWrapping="Wrap" Margin="0,0,0,15"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="OK" Click="OkButton_Click" Width="70" Margin="0,0,10,0" IsDefault="True"/>
                <Button Content="Отмена" Click="CancelButton_Click" Width="70" IsCancel="True"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>