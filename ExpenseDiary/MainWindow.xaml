<Window x:Class="ExpenseDiary.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:local="clr-namespace:ExpenseDiary"
        mc:Ignorable="d"
        Title="Дневник затрат" Height="484" Width="799">
    <TabControl Margin="0,0,0,-6">
        <TabItem Header="Таблица транзакций" DataContext="{Binding TransactionsVM}">
            <Grid Background="#FFE5E5E5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ToolBar x:Name="MyToolbar" 
                         Grid.Row="1" 
                         Visibility="Visible">
                    <Button Content="Добавить" Click="AddItem_Click" ToolTip="Добавить транзакцию" 
                            BorderBrush="LightGray" Background="WhiteSmoke" Width="93"/>
                </ToolBar>

                <DataGrid x:Name="MyDataGrid" 
                          Grid.Row="2"
                          ItemsSource="{Binding Transactions}"
                          AutoGenerateColumns="False" 
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          Margin="5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="Auto"/>
                        <DataGridTextColumn Header="Дата" Binding="{Binding Date, StringFormat='dd.MM.yyyy'}" Width="150"/>
                        <DataGridTextColumn Header="Сумма" Binding="{Binding Summ, StringFormat='{}{0:C2}'}" Width="100"/>
                        <DataGridTextColumn Header="Категория" Binding="{Binding RussianType}" Width="100"/>
                        <DataGridTextColumn Header="Комментарий" Binding="{Binding Commentary}" Width="*"/>
                    </DataGrid.Columns>
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Редактировать" Click="EditItem_Click"/>
                            <MenuItem Header="Удалить" Click="DeleteItem_Click"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>

                <Border Grid.Row="3" 
                        Background="LightGray" 
                        Padding="5" 
                        Margin="5,0,5,5">
                    <TextBlock Text="{Binding Transactions.Count, StringFormat='Всего транзакций: {0}'}" 
                           FontWeight="Bold" Margin="0,0,15,0"/>
                </Border>
            </Grid>
        </TabItem>

        <TabItem Header="Статистика" DataContext="{Binding StatisticsVM}">
            <Grid Background="#FFE5E5E5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="LightGray" Padding="5" Margin="5">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding TransactionCount, StringFormat='Всего транзакций: {0}'}" 
                           FontWeight="Bold" Margin="0,0,15,0"/>
                        <TextBlock Text="{Binding ExpenseCount, StringFormat='Всего расходов: {0}'}" 
                           FontWeight="Bold" Margin="0,0,15,0"/>
                        <TextBlock Text="{Binding IncomeCount, StringFormat='Всего доходов: {0}'}" 
                           FontWeight="Bold" Margin="0,0,15,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Background="LightGray" Padding="5" Margin="5">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding TotalSum, StringFormat='Сумма за всё время: {0:C}'}" 
                           FontWeight="Bold" Margin="0,0,15,0"/>
                        <TextBlock Text="{Binding IncomeSum, StringFormat='Сумма доходов: {0:C}'}" 
                           FontWeight="Bold" Margin="0,0,15,0"/>
                        <TextBlock Text="{Binding ExpenseSum, StringFormat='Сумма расходов: {0:C}'}" 
                           FontWeight="Bold" Margin="0,0,15,0"/>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="2" Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Column="0" Background="White" BorderBrush="Gray" BorderThickness="1" Margin="5" Padding="5">
                        <StackPanel>
                            <TextBlock Text="Динамика доходов и расходов" FontWeight="Bold" TextAlignment="Center"/>
                            <lvc:CartesianChart Series="{Binding IncomeExpenseSeries}"
                                        XAxes="{Binding XAxes}"
                                        YAxes="{Binding YAxes}"
                                        Height="250" Width="Auto"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="White" BorderBrush="Gray" BorderThickness="1" Margin="5" Padding="5">
                        <StackPanel>
                            <TextBlock Text="Соотношение доходов и расходов" FontWeight="Bold" TextAlignment="Center"/>
                            <lvc:PieChart Series="{Binding IncomeExpensePieSeries}" Height="250" Width="Auto"/>
                        </StackPanel>
                    </Border>
                </Grid>
                <Border Grid.Row="3" Background="LightGray" Padding="5" Margin="5,5,5,10" Grid.RowSpan="2">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,-5">
                        <TextBlock Text="Начало : " FontWeight="Bold" Margin="0,0,5,0"/>
                        <DatePicker SelectedDate="{Binding StartDate, Mode=TwoWay}" 
                    Width="110" Margin="0,0,15,0"/>

                        <TextBlock Text="Конец : " FontWeight="Bold" Margin="0,0,5,0"/>
                        <DatePicker SelectedDate="{Binding EndDate, Mode=TwoWay}" 
                    Width="110" Margin="0,0,15,0"/>

                        <TextBlock Text="{Binding PeriodSum, StringFormat='Сумма за период: {0:C}'}" 
                   FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </Grid>
        </TabItem>
    </TabControl>
</Window>
